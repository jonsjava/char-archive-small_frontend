# Copy to .env in this directory and edit before running docker compose.
# Or run ./setup.sh (Linux/macOS) / setup.ps1 (Windows) to generate this automatically.

# Bind published ports to this host IP (Tailscale IP, 127.0.0.1, or 0.0.0.0 for all interfaces).
BIND_HOST=0.0.0.0

POSTGRES_USER=char_archive
POSTGRES_PASSWORD=changeme
POSTGRES_DB=char_archive
POSTGRES_PORT=5432

PGADMIN_DEFAULT_EMAIL=admin@chararchive.dev
PGADMIN_DEFAULT_PASSWORD=changeme
PGADMIN_PORT=5050

FRONTEND_PORT=8080

# Torrent download directory (contains database.dump and archive/ after extracting archive.7z.*).
# setup.sh sets these from a single --torrent-dir prompt.
TORRENT_DIR=/path/to/character-archive-final-torrent
ARCHIVE_HOST_PATH=/path/to/character-archive-final-torrent/archive
DATABASE_DUMP_PATH=/path/to/character-archive-final-torrent/database.dump

# Character Archive torrent image layout (do not change unless your files differ).
IMAGE_LAYOUT=sharded
IMAGE_SUBDIR=hashed-data
ENABLE_BROWSE_ALL=false
