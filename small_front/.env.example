# Copy to .env in this directory and edit before running dev scripts.
#
# Linux/macOS:  ./runme.sh  ./rebuild_tags.sh
# Windows:      .\runme.ps1  .\rebuild_tags.ps1
# Import watcher also runs automatically via runme (ENABLE_IMPORT_SCANNER=true).
# Or run standalone: python import_watcher.py / .\import_watcher.ps1

DB_HOST=localhost
DB_PORT=5432
DB_NAME=char_archive
DB_USER=char_archive
DB_PASSWORD=changeme

# Path to extracted torrent archive/ folder (contains hashed-data/)
ARCHIVE_PATH=/path/to/character-archive-final-torrent/archive

# Character Archive torrent uses sharded layout under hashed-data/
IMAGE_LAYOUT=sharded
IMAGE_SUBDIR=hashed-data

# Scan import/ for new cards while the app runs locally (runme.sh / runme.ps1).
# Docker uses the separate importer service — leave false or unset in Docker .env.
ENABLE_IMPORT_SCANNER=true
IMPORT_DIR=../import
IMPORT_SCAN_INTERVAL=60

# Set true to let users click the stats line to browse the full archive.
# Do not enable unless your server can handle this.
ENABLE_BROWSE_ALL=false

PORT=5000

# Python virtualenv used by runme / rebuild_tags / import_watcher scripts
# Linux/macOS: ~/venv   Windows: C:\Users\you\venv  or  .venv
VENV_PATH=~/venv
